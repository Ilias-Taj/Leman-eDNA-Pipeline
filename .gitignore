# Project .gitignore - files and folders that should not be checked into git

# Local conda env (recreate from environment.yml)
/env/

# Pipeline outputs and temporary results (ignore contents but keep folder structure)
/out/*
!/out/.gitkeep

# Raw input data (ignore contents but keep folder structure)
data/*
!data/.gitkeep

# Reference DB (ignore contents but keep folder structure)
refs/*
!refs/.gitkeep
!refs/*.py
!refs/*.sh

# Archived third-party or copied scripts
/archive/

# macOS metadata
.DS_Store

# Python cache files
__pycache__/
*.py[cod]

# Editor/IDE
.vscode/

# Presentation (not part of project)
Presentation_eDNA_Results.ipynb
